{
  "name": "emanuelecoppola/phpeg",
  "description": "A modern PHP PEG parsing library.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=8.1 <9.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5 || ^11.5",
    "symfony/polyfill-mbstring": "^1.37"
  },
  "autoload": {
    "psr-4": {
      "EmanueleCoppola\\PHPPeg\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "EmanueleCoppola\\PHPPeg\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "test:coverage": "phpunit --coverage-text"
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "repositories": [
    {
      "name": "packagist",
      "type": "composer",
      "url": "https://repo.packagist.org"
    }
  ]
}
